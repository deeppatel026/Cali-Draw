# Dependencies (reinstalled inside image)
**/node_modules

# Build outputs (rebuilt inside image)
**/.next
**/dist
**/.turbo

# Version control
.git
.gitignore

# Local env files (secrets must come from runtime env vars or CI secrets)
**/.env
**/.env.*
!**/.env.example

# Editor / OS artefacts
.DS_Store
**/.DS_Store
.idea
.vscode
*.swp
*.swo

# Test output
**/coverage
**/__tests__/snapshots

# Docker files themselves (not needed in build context)
Dockerfile*
docker-compose*.yml
.dockerignore

# Logs
**/*.log
**/npm-debug.log*
