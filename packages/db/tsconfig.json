{
    "extends": "@repo/typescript-config/base.json",
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "declaration": true,
        "declarationMap": false,
        "emitDeclarationOnly": false,
        "module": "CommonJS",
        "target": "ES2022",
        "esModuleInterop": true,
        "moduleResolution": "Node",
        "types": ["node"]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["dist", "node_modules", "prisma", "generated"]
}