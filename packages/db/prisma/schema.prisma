generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {

id   String  @id @default(uuid())
email  String  @unique
password  String
name  String
photo  String?
rooms   Room[]
chats   ChatArchive[]
}

model Room {
  id            Int           @id @default(autoincrement())
  slug          String        @unique
  name          String
  created_date  DateTime      @default(now())
  adminId       String
  admin         User          @relation(fields: [adminId], references: [id])
  chats         ChatArchive[]
  shapes        Shape[]
}

model Shape {
  id          String   @id @default(uuid())
  type        String
  data        String   // full shape JSON (color, strokeWidth, seed, type-specific coords)
  roomId      Int
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model ChatArchive {

id  Int @id @default(autoincrement())
message String
userId  String 
roomId  Int  
room    Room  @relation(fields: [roomId], references: [id])
user    User  @relation(fields: [userId], references: [id])

}
